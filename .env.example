# EmerCard local defaults. Copy to .env; never commit the copied file.
EMERCARD_ENVIRONMENT=local
EMERCARD_DEBUG=true
EMERCARD_HOST=127.0.0.1
EMERCARD_PORT=8000
EMERCARD_API_PREFIX=/api/v1
EMERCARD_LOG_LEVEL=INFO
EMERCARD_BUILD_REVISION=local

# Host-run API -> MongoDB published by Compose.
EMERCARD_MONGODB_URI=mongodb://localhost:27017
EMERCARD_MONGODB_DATABASE=emercard_local
EMERCARD_MONGODB_SERVER_SELECTION_TIMEOUT_MS=1500
EMERCARD_MONGODB_TLS_REQUIRED=false
EMERCARD_MONGODB_MIN_POOL_SIZE=0
EMERCARD_MONGODB_MAX_POOL_SIZE=20
EMERCARD_MONGODB_USERS_COLLECTION=users
EMERCARD_MONGODB_PROFILES_COLLECTION=medical_profiles
EMERCARD_MONGODB_TEST_DATABASE_PREFIX=emercard_test
# disabled | startup | command
EMERCARD_MONGODB_INDEX_INITIALIZATION_MODE=disabled

# JSON list, or comma-separated values are accepted by the settings parser.
EMERCARD_CORS_ORIGINS=["http://localhost:4321"]
EMERCARD_CORS_ALLOW_CREDENTIALS=false
EMERCARD_FRONTEND_BASE_URL=http://localhost:4321
EMERCARD_PUBLIC_LINK_TOKEN_BYTES=32
EMERCARD_PUBLIC_LINK_ROUTE_PREFIX=/p
EMERCARD_PUBLIC_LINK_EXPLICIT_PUBLICATION=true

# Deferred authentication settings. Auth is not implemented in Phase 1.
# EMERCARD_AUTH_SECRET=
EMERCARD_AUTH_ALGORITHM=HS256
EMERCARD_AUTH_ACCESS_TOKEN_LIFETIME_SECONDS=900
EMERCARD_AUTH_COOKIE_NAME=emercard_session
EMERCARD_AUTH_COOKIE_SECURE=false
EMERCARD_AUTH_COOKIE_HTTP_ONLY=true
EMERCARD_AUTH_COOKIE_SAME_SITE=lax
EMERCARD_AUTH_COOKIE_PATH=/
# EMERCARD_AUTH_COOKIE_DOMAIN=
EMERCARD_AUTH_CLOCK_SKEW_SECONDS=30

# Centralized profile validation limits.
EMERCARD_DISPLAY_NAME_MAX_LENGTH=120
EMERCARD_EMERGENCY_NOTE_MAX_LENGTH=500
EMERCARD_MEDICAL_ITEM_MAX_LENGTH=120
EMERCARD_MEDICAL_LIST_MAX_ITEMS=10
EMERCARD_EMERGENCY_CONTACTS_MAX_COUNT=5
EMERCARD_CONTACT_NAME_MAX_LENGTH=100
EMERCARD_CONTACT_RELATIONSHIP_MAX_LENGTH=80
EMERCARD_CONTACT_PHONE_MAX_LENGTH=32
EMERCARD_BIRTH_YEAR_MIN=1900
EMERCARD_BIRTH_YEAR_MAX=2026
